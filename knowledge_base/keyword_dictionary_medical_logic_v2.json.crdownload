  "medical_logic": {
    "bariatric": {
      "bmi_gate": {
        "rule": "Sleeve Gastrectomy covered ONLY if BMI > 40 (Morbid Obesity)",
        "engine_action": "AUTO_CALCULATE BMI from Weight(kg) / Height(m)^2 — do NOT accept manual entry",
        "rejection_condition": "BMI ≤ 40 → REJECT as cosmetic weight-loss procedure",
        "applies_to": [
          "Laparoscopic Sleeve Gastrectomy",
          "Sleeve Gastrectomy Robotic"
        ]
      },
      "bypass_band_default": {
        "rule": "Gastric Bypass and Lap Band are COSMETIC by default — not covered",
        "engine_action": "AUTO_REJECT unless BMI > 40 documented",
        "applies_to": [
          "Roux-en-Y Gastric Bypass",
          "Mini Gastric Bypass",
          "Band Removal",
          "Band to Sleeve Conversion",
          "Band to Bypass Conversion"
        ]
      },
      "revisional_complexity": {
        "rule": "All revisional bariatric procedures require primary surgery documentation",
        "required_docs": [
          "Previous bariatric operative note",
          "Prior BMI",
          "Indication for revision"
        ],
        "complexity_note": "Sleeve-to-Bypass, Band-to-Bypass, Re-sleeve = complexity score 7-8",
        "applies_to": [
          "Revisional Sleeve",
          "Sleeve to Bypass Conversion",
          "Sleeve Re-sleeve",
          "Sleeve to Mini Bypass",
          "Sleeve to Roux-en-Y",
          "Band to Bypass Conversion",
          "Gastric Bypass Revision",
          "Gastrojejunostomy Revision"
        ]
      },
      "leak_repair": {
        "rule": "Bariatric Leak Repair = COMMON COMPLICATION — not malpractice",
        "methylene_blue_gate": "Engine MUST check operative findings for Methylene Blue Test documentation — key quality indicator",
        "engine_action": "FLAG if Methylene Blue Test absent from operative notes",
        "applies_to": [
          "Bariatric Leak Repair Laparoscopic"
        ],
        "complexity_score": 9
      },
      "adhesiolysis_coverage": {
        "rule": "Adhesiolysis = standalone covered procedure ONLY when linked to Laparotomy or Repeated C-Sections (3+ times)",
        "engine_action": "APPROVE if linked to CS>3 or Laparotomy — REJECT as standalone cosmetic",
        "applies_to": [
          "Laparoscopic Adhesiolysis"
        ]
      },
      "laparoscopic_exploration": {
        "rule": "Laparoscopic Exploration preferred and approved over open midline exploration",
        "engine_action": "PRIORITIZE in approval workflow as modern standard of care",
        "applies_to": [
          "Diagnostic Laparoscopy"
        ]
      },
      "hernia_reflux_critical": {
        "rule": "Ventral Hernia, Hiatal Hernia, Fundoplication = HIGH RISK — flag for senior medical review",
        "hiatus_hernia_trap": "Hiatus hernia often misdiagnosed as GERD or Peptic Ulcer — flag for senior review",
        "engine_action": "FLAG_SENIOR_REVIEW for all hiatal hernia and fundoplication cases",
        "applies_to": [
          "Laparoscopic Fundoplication (Nissen)",
          "Hiatal Hernia Repair Laparoscopic",
          "Laparoscopic Ventral Hernia Repair",
          "Laparoscopic Incisional Hernia Repair"
        ]
      },
      "whipple_oncology": {
        "rule": "Whipple / Gastrojejunostomy = highly complex oncology. Engine must distinguish curative vs palliative intent",
        "required_docs": [
          "Tumor location (Pancreas head/tail, Gallbladder, Duodenum)",
          "Staging results",
          "Surgical intent"
        ],
        "engine_action": "FLAG_CURATIVE_VS_PALLIATIVE — coding differs significantly"
      }
    },
    "breast": {
      "reduction_mammoplasty": {
        "rule": "Breast Reduction = COSMETIC by default — covered ONLY if linked to chronic back pain or degenerative OA of thoracic/lumbar spine",
        "required_icd": "Must link ICD-10 code for Thoracic/Lumbar pain or OA to override cosmetic exclusion",
        "engine_action": "FLAG_REJECTION_RISK if no spinal ICD code present with breast reduction",
        "applies_to": [
          "Breast Reduction"
        ]
      },
      "oncologic_protocol": {
        "rule": "All malignant breast cases require wide local excision WITH guaranteed safety margin",
        "ln_mandatory": "LN excision mandatory for histopathological staging in all oncologic breast cases",
        "engine_action": "FLAG if Safety Margin and LN Excision not documented in operative findings",
        "applies_to": [
          "Lumpectomy (Wide Local Excision)",
          "Lumpectomy + Sentinel LN Biopsy",
          "Modified Radical Mastectomy (MRM)",
          "Skin-Sparing Mastectomy",
          "Nipple-Sparing Mastectomy"
        ]
      },
      "abscess_emergency": {
        "rule": "Breast Abscess = EMERGENCY — auto-approve, bypass standard pre-auth",
        "mastitis_lactational": "Lactational Mastitis = purely medical condition, fully covered, NOT subject to maternity sub-limits",
        "urgent_6_rule": "Priority emergency abscess types: Breast, Brain (2B), Lung, Liver (2L), Gluteal (G)",
        "engine_action": "AUTO_APPROVE — set urgency flag, bypass pre-authorization"
      },
      "cosmetic_exclusions": {
        "rule": "Strict cosmetic exclusions: Breast Augmentation, Mastopexy — auto-flag if submitted as medical",
        "engine_action": "AUTO_REJECT or FLAG_COSMETIC if submitted without medical necessity documentation",
        "applies_to": [
          "Breast Augmentation",
          "Mastopexy (Breast Lift)"
        ]
      },
      "biopsy_diagnostic": {
        "rule": "Core Needle Biopsy and Excisional Biopsy = diagnostic path for histopathology — covered",
        "engine_action": "APPROVE as diagnostic procedure — foundational for staging",
        "applies_to": [
          "Core Needle Biopsy Breast",
          "Excisional Biopsy Breast"
        ]
      },
      "free_flap_anastomosis": {
        "rule": "Breast Reconstruction Free Flap = highest complexity (9). Requires microvascular anastomosis documentation",
        "engine_action": "FLAG if anastomosis technique not documented in operative notes",
        "applies_to": [
          "Breast Reconstruction Free Flap"
        ]
      }
    },
    "plastic": {
      "skin_graft_coverage": {
        "rule": "STSG/FTSG generally covered — UNLESS injury caused by exclusion: extreme sports, war, self-inflicted",
        "los_benchmark": "Standard LOS = 1 day. First dressing change Day 5 — outpatient follow-up if stable, no comorbidities",
        "engine_action": "EXCLUSION_HUNTER: check mode of injury in ER notes for policy exclusions",
        "applies_to": [
          "Skin Graft Split Thickness",
          "Skin Graft Full Thickness"
        ]
      },
      "free_flap_complexity": {
        "rule": "Microvascular Free Flap = complexity 9, highest level — requires anastomosis documentation",
        "engine_action": "FLAG if microvascular anastomosis not documented in operative notes",
        "applies_to": [
          "Free Flap Microvascular"
        ]
      },
      "abdominoplasty": {
        "rule": "Abdominoplasty = COSMETIC by default — covered ONLY when linked to hernia repair (umbilical, para-umbilical, incisional)",
        "umbilical_coding": "Umbilical Reconstruction should be coded as ADDITIONAL procedure — reflects true surgical skill",
        "engine_action": "REJECT as cosmetic unless hernia ICD code present. FLAG umbilical reconstruction as add-on code",
        "applies_to": [
          "Abdominoplasty",
          "Abdominoplasty with Umbilical Transposition",
          "Umbilical Reconstruction"
        ]
      },
      "cosmetic_exclusions": {
        "rule": "Liposuction, Tissue Expanders, Scar Revision = cosmetic exclusions",
        "scar_revision_exception": "Scar Revision accepted ONLY as part of repeated C-section billing — NOT as standalone",
        "keloid_exception": "Keloid Excision rejected as cosmetic UNLESS keloid impairs vital function",
        "gynecomastia": "Gynecomastia = cosmetic/hormonal condition — check for lipoma tissue under nipple for any coverage",
        "engine_action": "AUTO_REJECT standalone scar revision. FLAG keloid without functional impairment documentation",
        "applies_to": [
          "Liposuction",
          "Scar Revision",
          "Keloid Excision",
          "Gynecomastia Excision",
          "Tissue Expander Placement",
          "Tissue Expander Removal"
        ]
      }
    },
    "orthopaedic": {
      "fixation_selection": {
        "plate_rule": "Plates & Screws (ORIF) = for articular/peri-articular fractures near joints",
        "im_nail_rule": "IM Nailing = for long bone SHAFT fractures (Femur, Humerus, Tibia)",
        "hardware_removal": "Hardware removal decision based on healing status on X-ray films",
        "fat_embolism_alert": "CRITICAL: Fat Embolism is high-risk specific complication in Femur nailing — flag",
        "engine_action": "HARDWARE_AUDITOR: verify fixation method matches fracture type in operative notes",
        "applies_to": [
          "ORIF Long Bone",
          "Intramedullary Nailing Femur",
          "Intramedullary Nailing Tibia",
          "Plating Humerus",
          "Plating Radius Ulna"
        ]
      },
      "mode_of_trauma": {
        "rule": "Engine MUST verify Mode of Trauma and Incident Cause for all fracture/trauma cases",
        "exclusion_check": "Non-covered if: professional sports, criminal acts, hazardous activities",
        "engine_action": "EXCLUSION_HUNTER — active for all trauma/fracture cases"
      },
      "hip_age_gate": {
        "rule": "DHS = first choice for YOUNGER patients without AVN. Hip Replacement = preferred for ELDERLY patients",
        "avn_check": "Engine must check for Avascular Necrosis (AVN) in diagnosis — changes DHS to replacement",
        "engine_action": "AGE_GATE: if elderly + hip fracture → recommend Hemiarthroplasty/THR over DHS",
        "applies_to": [
          "Dynamic Hip Screw (DHS)",
          "Total Hip Replacement",
          "Hemiarthroplasty Hip"
        ]
      },
      "knee_mri_gate": {
        "rule": "Knee Arthroscopy requires MRI confirmation of Grade 3 or 4 OA, degenerative tears, or patellar instability",
        "age_protocol": {
          "young": "Surgery is first-line — facilitate perfect recovery",
          "elderly": "Conservative first (Medical, Physio, Steroid/Hyaluronic injections) — surgery as LAST RESORT"
        },
        "prp_rejection": "PRP/Plasma injections = AUTO_REJECT — not FDA approved, classified as trial",
        "tkr_preexisting": "TKR frequently flagged as Pre-existing condition — watch for this flag",
        "engine_action": "FLAG if MRI report absent for knee arthroscopy. AUTO_REJECT PRP. FLAG TKR for pre-existing check",
        "applies_to": [
          "Knee Arthroscopy Diagnostic",
          "Meniscectomy Arthroscopic",
          "Total Knee Replacement",
          "ACL Reconstruction"
        ]
      },
      "shoulder_decompression": {
        "rule": "Shoulder decompression often flagged as Upcoding by insurers — engine should defend based on surgical standards",
        "engine_action": "FLAG_UPCODING_DEFENSE: document medical necessity for decompression procedures",
        "applies_to": [
          "Shoulder Arthroscopy",
          "Rotator Cuff Repair"
        ]
      },
      "spine_requirements": {
        "rule": "Spinal Fusion requires MRI confirmation AND proof of failed conservative management",
        "levels_complexity": "Complexity calculated by number of levels (1-level vs 3-level). More levels = higher complexity",
        "engine_action": "FLAG if MRI absent or conservative management history not documented for spine cases",
        "applies_to": [
          "Laminectomy Spine",
          "Discectomy Lumbar",
          "Spinal Fusion"
        ]
      },
      "congenital_exclusions": {
        "rule": "Scoliosis and Flatfoot = CONGENITAL conditions — strictly non-covered",
        "engine_action": "AUTO_REJECT — congenital exclusion"
      },
      "arthroplasty_requirements": {
        "rule": "TKR and THR require severe OA documentation. Hemiarthroplasty = elderly femoral neck fracture (emergency)",
        "tkr_imaging": "TKR requires AP X-ray showing aggressive OA",
        "engine_action": "FLAG if severe OA documentation absent for joint replacement cases",
        "applies_to": [
          "Total Knee Replacement",
          "Total Hip Replacement",
          "Hemiarthroplasty Hip"
        ]
      }
    }
  },
