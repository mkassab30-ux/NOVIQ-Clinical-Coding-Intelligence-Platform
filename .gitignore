[project]
name = "noviq-engine"
version = "0.1.0"
description = "AI-Powered Clinical Intelligence Layer for Upstream Revenue Cycle Optimization"
authors = [{ name = "Dr. Mohamed Ahmed Kassab" }]
readme = "README.md"
requires-python = ">=3.11"
license = { text = "MIT" }

dependencies = [
    "fastapi>=0.115.0",
    "uvicorn[standard]>=0.30.0",
    "pydantic>=2.9.0",
    "langgraph>=0.2.0",
    "llama-index>=0.11.0",
    "qdrant-client>=1.11.0",
    "neo4j>=5.25.0",
    "python-dotenv>=1.0.1",
    "pydantic-settings>=2.5.0",
]

[tool.ruff]
line-length = 120
target-version = "py311"

[tool.ruff.lint]
select = ["E", "F", "I", "B", "C4"]
ignore = ["E501"]

[tool.ruff.format]
quote-style = "double"